{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "srav1919"
		},
		"ls_sqldb_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sqldb'"
		},
		"ls_storagesai19_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_storagesai19'"
		},
		"ls_key_vault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://sai-keyv.vault.azure.net/"
		},
		"ls_sqldb_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sai-sqlserver.database.windows.net"
		},
		"ls_sqldb_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sai_database"
		},
		"ls_sqldb_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sai"
		},
		"ls_sqldb_with_keyvault_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "sai-sqlserver.database.windows.net"
		},
		"ls_sqldb_with_keyvault_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sai_database"
		},
		"ls_sqldb_with_keyvault_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sai"
		},
		"ls_storagesai19_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storagesai19.dfs.core.windows.net/"
		},
		"tg_event_trigger_example_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/e41896f4-d154-46d0-a6e2-e4229bc5cd68/resourceGroups/rs_sai/providers/Microsoft.Storage/storageAccounts/storagesai19"
		},
		"tg_tumbling_window_example_properties_pipeline_parameters_window_start_time": {
			"type": "string",
			"defaultValue": "@{trigger().outputs.windowStartTime}"
		},
		"tg_tumbling_window_example_properties_pipeline_parameters_window_end_time": {
			"type": "string",
			"defaultValue": "@{trigger().outputs.windowEndTime}"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "srav1919_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_sqldb_password": {
						"value": "[parameters('ls_sqldb_password')]"
					},
					"ls_storagesai19_accountKey": {
						"value": "[parameters('ls_storagesai19_accountKey')]"
					},
					"ls_key_vault_properties_typeProperties_baseUrl": {
						"value": "[parameters('ls_key_vault_properties_typeProperties_baseUrl')]"
					},
					"ls_sqldb_properties_typeProperties_server": {
						"value": "[parameters('ls_sqldb_properties_typeProperties_server')]"
					},
					"ls_sqldb_properties_typeProperties_database": {
						"value": "[parameters('ls_sqldb_properties_typeProperties_database')]"
					},
					"ls_sqldb_properties_typeProperties_userName": {
						"value": "[parameters('ls_sqldb_properties_typeProperties_userName')]"
					},
					"ls_storagesai19_properties_typeProperties_url": {
						"value": "[parameters('ls_storagesai19_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		},
		{
			"name": "srav1919_ArmTemplate_1",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_1.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_sqldb_with_keyvault_properties_typeProperties_server": {
						"value": "[parameters('ls_sqldb_with_keyvault_properties_typeProperties_server')]"
					},
					"ls_sqldb_with_keyvault_properties_typeProperties_database": {
						"value": "[parameters('ls_sqldb_with_keyvault_properties_typeProperties_database')]"
					},
					"ls_sqldb_with_keyvault_properties_typeProperties_userName": {
						"value": "[parameters('ls_sqldb_with_keyvault_properties_typeProperties_userName')]"
					},
					"tg_tumbling_window_example_properties_pipeline_parameters_window_start_time": {
						"value": "[parameters('tg_tumbling_window_example_properties_pipeline_parameters_window_start_time')]"
					},
					"tg_tumbling_window_example_properties_pipeline_parameters_window_end_time": {
						"value": "[parameters('tg_tumbling_window_example_properties_pipeline_parameters_window_end_time')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'srav1919_ArmTemplate_0')]"
			]
		},
		{
			"name": "srav1919_ArmTemplate_2",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_2.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'srav1919_ArmTemplate_1')]"
			]
		},
		{
			"name": "srav1919_ArmTemplate_3",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_3.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"tg_event_trigger_example_properties_typeProperties_scope": {
						"value": "[parameters('tg_event_trigger_example_properties_typeProperties_scope')]"
					}
				}
			},
			"dependsOn": [
				"[resourceId('Microsoft.Resources/deployments', 'srav1919_ArmTemplate_2')]"
			]
		}
	]
}