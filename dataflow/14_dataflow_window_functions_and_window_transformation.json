{
	"name": "14_dataflow_window_functions_and_window_transformation",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_src_df_gen2_window_function_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "ds_src_df_gen2_window_function_csv",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "ds_src_df_gen2_window_function_csv",
						"type": "DatasetReference"
					},
					"name": "source3"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sink_gen2_dataflow_result",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "Dense"
				},
				{
					"name": "DenseRank4"
				},
				{
					"name": "rank"
				},
				{
					"name": "Rank8"
				},
				{
					"name": "WindowTransformation"
				},
				{
					"name": "DeptWise2ndHighestSalary"
				}
			],
			"scriptLines": [
				"source(output(",
				"          empid as string,",
				"          empname as string,",
				"          gender as string,",
				"          deptno as string,",
				"          sal as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          empid as string,",
				"          empname as string,",
				"          gender as string,",
				"          deptno as string,",
				"          sal as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          empid as string,",
				"          empname as string,",
				"          gender as string,",
				"          deptno as string,",
				"          sal as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source1 rank(desc(sal, true),",
				"     output(dense_rank as long),",
				"     dense: true) ~> Dense",
				"Dense filter(dense_rank == 4) ~> DenseRank4",
				"source2 rank(desc(sal, true),",
				"     output(rank as long)) ~> rank",
				"rank filter(rank == 8) ~> Rank8",
				"source3 window(over(deptno),",
				"     desc(sal, true),",
				"     dense_rank = denseRank()) ~> WindowTransformation",
				"WindowTransformation filter(dense_rank == 2) ~> DeptWise2ndHighestSalary",
				"DeptWise2ndHighestSalary sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}