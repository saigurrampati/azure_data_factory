					},
					"name": "source3"
				},
				{
					"dataset": {
						"referenceName": "ds_src_gen2_cc2_csv",
						"type": "DatasetReference"
					},
					"name": "source4"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sink_azuredb_cust_dtls_table",
						"type": "DatasetReference"
					},
					"name": "sink1"
				},
				{
					"dataset": {
						"referenceName": "ds_sink_azuredb_cust_dtls_table",
						"type": "DatasetReference"
					},
					"name": "sink2"
				},
				{
					"dataset": {
						"referenceName": "ds_sink_azuredb_cust_dtls_table",
						"type": "DatasetReference"
					},
					"name": "sink3"
				},
				{
					"dataset": {
						"referenceName": "ds_sink_azuredb_cust_dtls_table",
						"type": "DatasetReference"
					},
					"name": "sink4"
				}
			],
			"transformations": [
				{
					"name": "DeleteRows"
				},
				{
					"name": "Update"
				},
				{
					"name": "updateAll"
				},
				{
					"name": "upsert"
				}
			],
			"scriptLines": [
				"source(output(",
				"          cust_id as string,",
				"          cust_name as string,",
				"          country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          cust_id as string,",
				"          cust_name as string,",
				"          country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          cust_id as string,",
				"          cust_name as string,",
				"          country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source3",
				"source(output(",
				"          cust_id as string,",
				"          cust_name as string,",
				"          country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source4",
				"source1 alterRow(deleteIf(country == 'USA')) ~> DeleteRows",
				"source2 alterRow(updateIf(country == 'USA')) ~> Update",
				"source3 alterRow(updateIf( true())) ~> updateAll",
				"source4 alterRow(upsertIf(true())) ~> upsert",
				"DeleteRows sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          cust_id as string,",
				"          cust_name as string,",
				"          country as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1",
				"Update sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          cust_id as string,",
				"          cust_name as string,",
				"          country as string",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['cust_id'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink2",
				"updateAll sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          cust_id as string,",
				"          cust_name as string,",
				"          country as string",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['cust_id'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink3",
				"upsert sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          cust_id as string,",
				"          cust_name as string,",
				"          country as string",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:false,",
				"     upsertable:true,",
				"     keys:['cust_id'],",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink4"
			]
		}
	}
}