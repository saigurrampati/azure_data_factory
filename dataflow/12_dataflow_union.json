{
	"name": "12_dataflow_union",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_src_dataflow_gen2_union_1",
						"type": "DatasetReference"
					},
					"name": "empinfo"
				},
				{
					"dataset": {
						"referenceName": "ds_src_dataflow_gen2_union_2",
						"type": "DatasetReference"
					},
					"name": "deptinfo"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sink_gen2_dataflow_result",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "union1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          empid as string,",
				"          empname as string,",
				"          sal as string,",
				"          gender as string,",
				"          deptno as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> empinfo",
				"source(output(",
				"          empid as string,",
				"          empname as string,",
				"          sal as string,",
				"          gender as string,",
				"          deptno as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> deptinfo",
				"empinfo, deptinfo union(byName: true)~> union1",
				"union1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}