{
	"name": "19_dataflow_flowlet_emp11_csv_example_required_for",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_src_gen2_flowlet_emp11_csv",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "ds_src_gen2_flowlet_dept11_csv",
						"type": "DatasetReference"
					},
					"name": "source2"
				},
				{
					"dataset": {
						"referenceName": "ds_src_gen2_flowlet_emp11_csv",
						"type": "DatasetReference"
					},
					"name": "empdata"
				},
				{
					"dataset": {
						"referenceName": "ds_src_gen2_flowlet_dept11_csv",
						"type": "DatasetReference"
					},
					"name": "deptdata"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sink_gen2_dataflow_result",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "aggregate1"
				},
				{
					"name": "select1"
				},
				{
					"name": "aggregate2"
				},
				{
					"name": "select2"
				},
				{
					"name": "usingFlowlet",
					"flowlet": {
						"referenceName": "1_flowlet",
						"type": "DataFlowReference"
					}
				},
				{
					"name": "flowlet1",
					"flowlet": {
						"referenceName": "1_flowlet",
						"type": "DataFlowReference"
					}
				}
			],
			"scriptLines": [
				"source(output(",
				"          empid as string,",
				"          empname as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source(output(",
				"          deptid as string,",
				"          deptname as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source2",
				"source(output(",
				"          empid as string,",
				"          empname as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> empdata",
				"source(output(",
				"          deptid as string,",
				"          deptname as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> deptdata",
				"source1 aggregate(groupBy(empid,",
				"          empname),",
				"     count = count()) ~> aggregate1",
				"aggregate1 select(mapColumn(",
				"          empid,",
				"          empname",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"source2 aggregate(groupBy(deptid,",
				"          deptname),",
				"     count = count()) ~> aggregate2",
				"aggregate2 select(mapColumn(",
				"          deptid,",
				"          deptname",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"empdata compose(mapColumn(",
				"          id = empid,",
				"          name = empname",
				"     ),",
				"     composition: '1_flowlet') ~> usingFlowlet@(output1)",
				"deptdata compose(mapColumn(",
				"          id = deptid,",
				"          name = deptname",
				"     ),",
				"     composition: '1_flowlet') ~> flowlet1@(output1)",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1"
			]
		}
	}
}